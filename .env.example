# profanity-hush — docker-compose environment
# Copy this file to .env and edit the paths for your machine.
# .env is intentionally git-ignored (machine-specific paths).
#
# All paths must be absolute.

# ── Required ─────────────────────────────────────────────────────────────
# Directory containing the source video file(s).
INPUT_DIR=/home/yourname/Movies

# ── Optional ─────────────────────────────────────────────────────────────
# Where to write the censored output (default: same as INPUT_DIR)
# OUTPUT_DIR=/home/yourname/Movies/censored

# Config directory containing config.yaml and word_list.txt
# CONFIG_DIR=/home/yourname/.config/profanity-hush

# Model weight cache — keep this persistent and roomy (2-3 GB)
# CACHE_DIR=/home/yourname/.cache/profanity-hush

# Job history: transcript JSON, censor log, resume artifacts
# JOBS_DIR=/home/yourname/.local/share/profanity-hush/jobs

# ── Logging / behaviour ───────────────────────────────────────────────────
# AC_LOG_LEVEL=info          # debug | info | warning
# AC_KEEP_INTERMEDIATES=0    # 1 = keep large intermediate WAV stems after run
